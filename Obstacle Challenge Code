#include "MatrixMiniR4.h"

#define MOTOR_SPEED 25
#define TURN_SPEED 35
#define CAMERA_SPEED 22

#define SERVO_CENTER 83
#define SERVO_RIGHT 55
#define SERVO_LEFT 105

#define TURN_TIME 2000
#define WALL_TIME 1750

#define REVERSE_SPEED -20
#define REVERSE_TIME 2000

#define TOTAL_LINES 12
#define STOP_DELAY 3000

#define BLOCK_MEMORY 500
#define BLOCK_LOCK_TIME 800

String camColor = "NONE";

// camera tracking
String activeColor = "NONE";
unsigned long lastSeenTime = 0;

// block lock
bool chasingBlock = false;
unsigned long lastBlockTime = 0;

int direction = 0;
int lineCount = 0;
bool onLine = false;
bool finished = false;

bool waitingToStop = false;
unsigned long finishTime = 0;

unsigned long startTime;

void setup() {
  Serial.begin(115200);
  Serial1.begin(115200);

  MiniR4.begin();
  MiniR4.PWR.setBattCell(2);

  MiniR4.I2C2.MXLaserV2.begin(); // front
  MiniR4.I2C3.MXLaserV2.begin(); // left laser (NOW USED)
  MiniR4.I2C4.MXColorV3.begin();

  MiniR4.RC1.setAngle(SERVO_CENTER);
  MiniR4.M1.setSpeed(MOTOR_SPEED);

  startTime = millis();
}

void loop() {

  int frontDist = MiniR4.I2C2.MXLaserV2.getDistance();
  int leftDist  = MiniR4.I2C3.MXLaserV2.getDistance(); // 

  uint16_t r = MiniR4.I2C4.MXColorV3.getRaw_R();
  uint16_t g = MiniR4.I2C4.MXColorV3.getRaw_G();
  uint16_t b = MiniR4.I2C4.MXColorV3.getRaw_B();

  // CAMERA INPUT
  if (Serial1.available()) {
    camColor = Serial1.readStringUntil('\n');
    camColor.trim();
  }

  // block tracking
  if (camColor == "RED" || camColor == "GREEN") {
    activeColor = camColor;
    lastSeenTime = millis();
    chasingBlock = true;
    lastBlockTime = millis();
  }

  if (millis() - lastSeenTime > BLOCK_MEMORY) {
    activeColor = "NONE";
  }

  if (millis() - lastBlockTime > BLOCK_LOCK_TIME) {
    chasingBlock = false;
  }

  // COLOR DETECTION
  bool isWhite = (g > 150 && r > 110 && b > 130);

  bool isOrangeReal =
    !isWhite &&
    (r > 80 && r < 250) &&
    (g > 50 && g < 100) &&
    (b > 0 && b < 80) &&
    (r > g) &&
    (g > b);

  bool isBlueReal =
    !isWhite &&
    (r < 60) &&
    (g > 30 && g < 70) &&
    (b > 50 && b < 250) &&
    (b > g);

  if (finished) {
    MiniR4.M1.setSpeed(0);
    MiniR4.RC1.setAngle(SERVO_CENTER);
    return;
  }

  // Direction
  if (millis() - startTime > 2000 && !isWhite) {
    if (direction == 0) {
      if (isOrangeReal) direction = 1;
      else if (isBlueReal) direction = -1;
    }
  }

  // Line count
  bool correctLine =
    !isWhite &&
    ((direction == 1 && isOrangeReal) ||
     (direction == -1 && isBlueReal));

  if (correctLine && !onLine) {
    lineCount++;
    onLine = true;

    if (lineCount >= TOTAL_LINES && !waitingToStop) {
      waitingToStop = true;
      finishTime = millis();
    }
  }

  if (!correctLine) onLine = false;

  // Stop
  if (waitingToStop) {
    if (millis() - finishTime >= STOP_DELAY) {
      MiniR4.M1.setSpeed(0);
      MiniR4.RC1.setAngle(SERVO_CENTER);
      finished = true;
      return;
    }
  }

  // Color turns
  if (direction == 1 && isOrangeReal) {
    MiniR4.RC1.setAngle(SERVO_RIGHT);
    MiniR4.M1.setSpeed(TURN_SPEED);
    delay(TURN_TIME);
    return;
  }
  else if (direction == -1 && isBlueReal) {
    MiniR4.RC1.setAngle(SERVO_LEFT);
    MiniR4.M1.setSpeed(TURN_SPEED);
    delay(TURN_TIME);
    return;
  }

  // Front obstacle (ignore blocks)
  if (frontDist > 0 && frontDist < 400 && !chasingBlock) {

    MiniR4.M1.setSpeed(0);
    delay(150);

    MiniR4.M1.setSpeed(REVERSE_SPEED);
    MiniR4.RC1.setAngle(SERVO_CENTER);
    delay(REVERSE_TIME);

    if (direction == 1) MiniR4.RC1.setAngle(SERVO_RIGHT);
    else MiniR4.RC1.setAngle(SERVO_LEFT);

    MiniR4.M1.setSpeed(TURN_SPEED);
    delay(WALL_TIME);
    return;
  }

  // SOFT STABILIZATION (ONLY WHEN NO BLOCK)
  if (!chasingBlock && leftDist > 0) {

    if (leftDist < 350) {
      MiniR4.RC1.setAngle(SERVO_RIGHT);
      MiniR4.M1.setSpeed(MOTOR_SPEED);
      delay(80);
    }
    else if (leftDist > 650) {
      MiniR4.RC1.setAngle(SERVO_LEFT);
      MiniR4.M1.setSpeed(MOTOR_SPEED);
      delay(80);
    }
  }

  // Camera targeting
  if (activeColor == "RED") {
    MiniR4.RC1.setAngle(SERVO_RIGHT);
    MiniR4.M1.setSpeed(CAMERA_SPEED);
  }
  else if (activeColor == "GREEN") {
    MiniR4.RC1.setAngle(SERVO_LEFT);
    MiniR4.M1.setSpeed(CAMERA_SPEED);
  }
  else {
    MiniR4.RC1.setAngle(SERVO_CENTER);
    MiniR4.M1.setSpeed(MOTOR_SPEED);
  }

  delay(50);
}\
