#include "MatrixMiniR4.h"

#define MOTOR_SPEED 30
#define TURN_SPEED 35
#define SERVO_CENTER 83
#define SERVO_RIGHT 55
#define SERVO_LEFT 105

#define TURN_TIME 3500
#define WALL_TIME 1750

#define REVERSE_SPEED -20
#define REVERSE_TIME 2000

#define LEFT_CLOSE 400
#define LEFT_FAR 600
#define STABILIZE_TIME 200

#define TOTAL_LINES 12
#define STOP_DELAY 3000

int direction = 0;
int lineCount = 0;
bool onLine = false;
bool finished = false;

bool waitingToStop = false;
unsigned long finishTime = 0;

unsigned long startTime;

void setup() {
  Serial.begin(115200);
  MiniR4.begin();
  MiniR4.PWR.setBattCell(2);

  MiniR4.I2C2.MXLaserV2.begin();
  MiniR4.I2C3.MXLaserV2.begin();
  MiniR4.I2C4.MXColorV3.begin();

  MiniR4.RC1.setAngle(SERVO_CENTER);
  MiniR4.M1.setSpeed(MOTOR_SPEED);

  startTime = millis();
}

void loop() {
  int frontDist = MiniR4.I2C2.MXLaserV2.getDistance();
  int leftDist  = MiniR4.I2C3.MXLaserV2.getDistance();

  uint16_t r = MiniR4.I2C4.MXColorV3.getRaw_R();
  uint16_t g = MiniR4.I2C4.MXColorV3.getRaw_G();
  uint16_t b = MiniR4.I2C4.MXColorV3.getRaw_B();

  // WHITE
  bool isWhite = (g > 150 && r > 110 && b > 130);

  // ORANGE
  bool isOrangeReal =
    !isWhite &&
    (r > 30 && r < 210) &&
    (g > 50 && g < 100) &&
    (b > 0 && b < 80) &&
    (r > g) &&
    (g > b);

  // BLUE (fixed)
  bool isBlueReal =
    !isWhite &&
    (r < 60) &&
    (g > 30 && g < 70) &&
    (b > 50 && b < 250) &&
    (b > g);

  if (finished) {
    MiniR4.M1.setSpeed(0);
    MiniR4.RC1.setAngle(SERVO_CENTER);
    return;
  }

  // Direction decision
  if (millis() - startTime > 2000 && !isWhite) {
    if (direction == 0) {
      if (isOrangeReal) direction = 1;
      else if (isBlueReal) direction = -1;
    }
  }

  // Line detection
  bool correctLine =
    !isWhite &&
    ((direction == 1 && isOrangeReal) ||
     (direction == -1 && isBlueReal));

  if (correctLine && !onLine) {
    lineCount++;
    onLine = true;

    Serial.print("Line count: ");
    Serial.println(lineCount);

    if (lineCount >= TOTAL_LINES && !waitingToStop) {
      waitingToStop = true;
      finishTime = millis();
    }
  }

  if (!correctLine) {
    onLine = false;
  }

  // Delayed stop
  if (waitingToStop) {
    if (millis() - finishTime >= STOP_DELAY) {
      MiniR4.M1.setSpeed(0);
      MiniR4.RC1.setAngle(SERVO_CENTER);
      finished = true;
      return;
    }
  }

  // COLOR TURN
  if (direction == 1 && isOrangeReal) {
    MiniR4.RC1.setAngle(SERVO_RIGHT);
    MiniR4.M1.setSpeed(TURN_SPEED);
    delay(TURN_TIME);
  }
  else if (direction == -1 && isBlueReal) {
    MiniR4.RC1.setAngle(SERVO_LEFT);
    MiniR4.M1.setSpeed(TURN_SPEED);
    delay(TURN_TIME);
  }

  // FRONT WALL
  if (frontDist > 0 && frontDist < 400) {
    MiniR4.M1.setSpeed(0);
    delay(200);

    MiniR4.M1.setSpeed(REVERSE_SPEED);
    MiniR4.RC1.setAngle(SERVO_CENTER);
    delay(REVERSE_TIME);

    if (direction == 1) {
      MiniR4.RC1.setAngle(SERVO_RIGHT);
    } else {
      MiniR4.RC1.setAngle(SERVO_LEFT);
    }

    MiniR4.M1.setSpeed(TURN_SPEED);
    delay(WALL_TIME);
    return;
  }

 // SMART WALL STABILIZATION (WITH LIMIT)
if (leftDist > 0) {

  if (direction == 1) { // CLOCKWISE

    if (leftDist < LEFT_CLOSE) {
      MiniR4.RC1.setAngle(SERVO_RIGHT);
      MiniR4.M1.setSpeed(MOTOR_SPEED);
      delay(STABILIZE_TIME);
    }
    else if (leftDist > LEFT_FAR ) {
      MiniR4.RC1.setAngle(SERVO_LEFT);
      MiniR4.M1.setSpeed(MOTOR_SPEED);
      delay(STABILIZE_TIME);
    }

  } 
  else if (direction == -1) { // COUNTERCLOCKWISE

    if (leftDist < LEFT_CLOSE || leftDist > 900) {
      MiniR4.RC1.setAngle(SERVO_RIGHT);
      MiniR4.M1.setSpeed(MOTOR_SPEED);
      delay(STABILIZE_TIME);
    }
    else if (leftDist > LEFT_FAR && leftDist < 750) {
      MiniR4.RC1.setAngle(SERVO_LEFT);
      MiniR4.M1.setSpeed(MOTOR_SPEED);
      delay(STABILIZE_TIME);
    }

  }
}

  // NORMAL DRIVE
  MiniR4.RC1.setAngle(SERVO_CENTER);
  MiniR4.M1.setSpeed(MOTOR_SPEED);

  delay(50);
}
